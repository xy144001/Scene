# Copy this file to .env and edit paths for the target machine.

export SAGE_ROOT="/path/to/tree_sage_flow2_repro"
export SAGE_DATA_ROOT="/data/xy/SAGE_runs"

# Python environments.
export SAGE_ORCH_PYTHON="/data/xy/SAGE_repro/venv/bin/python"
export SAGE_TRELLIS_PYTHON="/home/xy/PAT3D/pat3d_stage2/pat2/bin/python"
export SAGE_REFERENCE_DEPTH_PY="/home/xy/PAT3D/pat3d_stage1/pat/bin/python"
export SAGE_FLOW2_MUJOCO_PY="/home/xy/PAT3D/pat3d_stage3/pat3/bin/python"
export SAGE_FLUX2_PYTHON="/home/xy/PAT3D/pat3d_stage1/pat/bin/python"

# External binaries.
export SAGE_BLENDER_BIN="/data/xy/tools/blender-4.3.2-linux-x64/blender"

# TRELLIS.2.
export SAGE_TRELLIS_REPO="/home/xy/PAT3D/pat3d_stage2/vendor/TRELLIS.2"
export SAGE_TRELLIS_MODEL="/data/xy/pat3d_stage2_data/models/trellis2_primary"
export SAGE_TRELLIS_OUTPUT_DIR="/data/xy/SAGE_repro/trellis2_bridge"
export SAGE_TRELLIS_URL="http://127.0.0.1:8082"
export SAGE_TRELLIS_HOST="127.0.0.1"
export SAGE_TRELLIS_PORT="8082"

# Background removal for TRELLIS.2 preprocessing.
export SAGE_RMBG_MODEL="/data/xy/pat3d_stage2_data/models/rmbg_2_0"
export SAGE_RMBG_MODULE_ROOT="/data/xy/pat3d_stage2_data/cache/hf_home/modules"

# Reference depth model.
export SAGE_REFERENCE_DEPTH_MODEL="/data/xy/pat3d_stage1_data/models/depth__large_relative"

# Optional local Flux servers. Not required when image2 source images are supplied.
export SAGE_FLUX2_MODEL="/data/xy/models/FLUX.2-klein-9B"
export SAGE_FLUX2_OUTPUT_DIR="/data/xy/SAGE_repro/flux2_klein_images"
export SAGE_FLUX1_MODEL="/data/xy/pat3d_stage1_data/models/text_to_image__primary"

# Codex agent model used by Flow2 JSON agents.
export SAGE_CODEX_MODEL="gpt-5"
